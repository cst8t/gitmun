{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gitmun",
  "version": "0.1.0",
  "identifier": "com.cst8t.gitmun",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gitmun",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost blob:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "untrusted comment: minisign public key: 9412D7FB0B0ADF09\nRWQJ3woL+9cSlIx9wcac+fBmeQP1XHhSTuZYxrQZdnNXvuPUOHT4Salc",
      "endpoints": [
        "https://github.com/cst8t/gitmun/releases/latest/download/latest.json"
      ]
    }
  }
}
