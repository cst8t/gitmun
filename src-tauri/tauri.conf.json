{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gitmun",
  "version": "0.1.0",
  "identifier": "com.cst8t.gitmun",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gitmun",
        "width": 1180,
        "height": 700,
        "minWidth": 1180,
        "minHeight": 700,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost blob:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": ["git"]
      },
      "rpm": {
        "depends": ["git"]
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2NDc3MkM3MEEyNDYwMDEKUldRQllDUUt4M0pIeG0wL0Nsb3NGaE5QbDFtWTRmbFFIQWdCNURxOXpNd05kQWxCSWJoRllRZSsK",
      "endpoints": [
        "https://github.com/cst8t/gitmun/releases/latest/download/latest.json"
      ]
    }
  }
}
